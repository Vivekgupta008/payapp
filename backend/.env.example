# Copy to .env for local development (never commit .env)

# JWT secret — use a strong random value in production
SECRET_KEY=hackathon-offline-pay-secret-2024

# Database
# Local:      sqlite:///./offline_pay.db
# Production: postgresql://user:pass@host/dbname  (Render injects this automatically)
DATABASE_URL=sqlite:///./offline_pay.db

# Ed25519 signing key (base64-encoded raw 32-byte private key)
# Leave empty locally — key will be generated and saved to keys/ed25519.key
# In production: copy the value printed in logs on first deploy
ED25519_PRIVATE_KEY_B64=
